PORT=4000
JWT_SECRET=change-this-to-a-long-random-secret
ADMIN_EMAIL=himanshupanchal@gamil.com

# Postgres connection string (e.g. from a Render Postgres instance).
# Without this set, data is stored in local JSON files under backend/data/
# instead — fine for local dev, but those files don't survive a redeploy on
# hosts with ephemeral disks (like Render's free web service tier).
DATABASE_URL=

# Razorpay (https://dashboard.razorpay.com/app/keys) — required for online payments.
# Without these set, only Cash on Delivery checkout will work.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
